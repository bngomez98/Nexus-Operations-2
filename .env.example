# ─── Supabase ───────────────────────────────────────────────────────────────
# Find these in: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# (Optional) Override the OAuth redirect URL in local development
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Find these in: https://dashboard.stripe.com/apikeys
# Use sk_test_... keys in development, sk_live_... in production
STRIPE_SECRET_KEY=sk_test_...

# ─── Application ────────────────────────────────────────────────────────────
# Full URL of your deployment — used for Stripe success/cancel redirect URLs.
# In development this is usually http://localhost:3000
# In production set this to your live domain, e.g. https://nexusoperations.org
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Nexus Operations - Environment Variables
# Copy this file to .env.local and fill in values for local development.

# ── Stripe ──────────────────────────────────────────────────────────────────
# Required for the contractor subscription / checkout flow.
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Application ──────────────────────────────────────────────────────────────
# Base URL used to build Stripe redirect URLs.
# For local development this should be http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Node ─────────────────────────────────────────────────────────────────────
# Set automatically by Next.js; listed here for reference only.
# NODE_ENV=development
